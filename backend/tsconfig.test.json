// used for configuring unit tests in ts
{
    "compilerOptions": {
        "target": "es2025",
        "module": "commonjs",
        "outDir" : "./dist",
        "rootDir" : "..",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "moduleResolution": "node"
    },
    "include": [
        "**/*.ts",
        "../shared/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}