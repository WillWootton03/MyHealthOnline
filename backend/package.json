{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "test": "npm run test::unit && npm run test::integration",
    "test:unit": "jest --config jest.config.js --testMatch='**/*.unit.test.ts' --force-exit",
    "test:integration": "jest --config jest.config.js --testMatch='**/*.int.test.js' --force-exit",
    "test:watch": "jest --config jest.config.js --testMatch='**/*.unit.test.ts' --watchAll",
    "start": "node app.js",
    "dev": "nodemon -L --exec tsx app.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "argon2": "^0.44.0",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-errors": "^2.0.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "winston": "^3.19.0"
  }
}
